{
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!api/|landing\\.html).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron-agents", "schedule": "0 6,11 * * *" }
  ]
}
